# =============================================
# Join Events — Root environment file (example)
# Copy this file to .env and fill in real values.
# Each app (web, api) also has its own .env.
# =============================================

# Postgres (used by docker-compose and the api)
POSTGRES_USER=joinevents
POSTGRES_PASSWORD=joinevents_dev_password
POSTGRES_DB=joinevents
POSTGRES_PORT=5432

# Redis (used by docker-compose and the api)
REDIS_PORT=6379
