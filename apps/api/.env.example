# =============================================
# Join Events API — env reference
# Copy to .env for local dev (gitignored).
# All vars validated by src/env.ts at boot.
# =============================================

NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# CORS — comma separated allow-list. NO localhost in production.
CORS_ORIGINS=http://localhost:3000

# ---------- Postgres ----------
DATABASE_URL=postgresql://joinevents:joinevents_dev_password@localhost:5432/joinevents?schema=public
PRISMA_CONNECTION_LIMIT=20
# DATABASE_URL_READ_1=postgresql://joinevents:joinevents_dev_password@localhost:5433/joinevents?schema=public
# DATABASE_URL_READ_2=postgresql://joinevents:joinevents_dev_password@localhost:5434/joinevents?schema=public

# Test DB (required to run `pnpm test`)
DATABASE_URL_TEST=postgresql://joinevents:joinevents_dev_password@localhost:5432/joinevents_test?schema=public

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379

# ---------- Meilisearch ----------
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=meili-dev-master-key-change-me

# ---------- Auth ----------
# Must be ≥32 chars. In production, generate via: openssl rand -hex 32
JWT_SECRET=dev-only-change-me-please-32-chars-min-secret-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# ---------- OTP ----------
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_REQUEST_LIMIT=3
OTP_REQUEST_WINDOW_SECONDS=900
OTP_RETURN_IN_RESPONSE=true   # MUST be false in production

# ---------- SMS provider ----------
SMS_PROVIDER=stub             # → 'msg91' in production
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_TEMPLATE_ID=

# ---------- Payments (PayU) ----------
PAYU_PROVIDER=stub            # → 'live' in production
PAYU_MERCHANT_KEY=
PAYU_MERCHANT_SALT=
PAYU_WEBHOOK_SECRET=

# ---------- Storage (file uploads) ----------
STORAGE_DRIVER=local          # 'local' | 'r2' | 's3'. NEVER 'local' in production.
STORAGE_LOCAL_DIR=./uploads
STORAGE_R2_ACCOUNT_ID=
STORAGE_R2_BUCKET=
STORAGE_R2_ACCESS_KEY=
STORAGE_R2_SECRET_KEY=
STORAGE_R2_PUBLIC_URL=        # e.g. https://cdn.joinevents.in

# ---------- Observability ----------
# Required in production. Get from sentry.io project settings.
SENTRY_DSN=

# ---------- Rate limiting (global) ----------
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=120            # requests per window per IP

# ---------- Queue ----------
QUEUE_DISABLED=false          # set true if Redis flaky locally
