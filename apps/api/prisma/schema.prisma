// Join Events — Prisma schema
// Step 2: 5 core tables (users, business_profiles, societies, events, stalls)
// Step 3: + user_sessions (refresh-token rotation)
// Step 6: + wallets, wallet_entries, payment_events (double-entry ledger)
// Step 6b: + bookings (vendor books a stall; money moves via WalletService)
// Step 7:  + reviews (event ratings, Bayesian aggregate to organiser)
// Step 7b: + followers (user ↔ business_profile junction)
// Step 8:  + admin_audit_logs + User.isAdmin
// Step 7d: + notifications (in-app, polled)
// FINAL:   + withdrawal_requests + featured_listings (revenue + payouts)
// CLOSEOUT: + verification_requests + kyc_documents + subscription_plans
//           + subscriptions + society_posts + post_replies
// Tables we will add in later steps (with the feature that needs them):
//   - device_tokens          (Step 7d.2: web push)
//
// All money is stored as integer paise (₹1 = 100 paise) — never as a float.
// All timestamps are TIMESTAMPTZ (Prisma's @db.Timestamptz).
// All IDs are UUIDs generated by Postgres (uuid-ossp / gen_random_uuid).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  // "native"                   → engine for the host that runs `prisma generate`
  // "linux-musl-openssl-3.0.x" → required when the runtime image is Alpine +
  //                              Node 20+ (Railway / our Dockerfile.api).
  // Without this the container crashes at boot with
  // PrismaClientInitializationError: Unable to require libquery_engine.
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis, uuidOssp(map: "uuid-ossp"), citext, pgTrgm(map: "pg_trgm"), pgcrypto]
}

// =================================================================
// USERS  —  every human on the platform, regardless of role
// =================================================================
model User {
  id            String    @id @default(uuid()) @db.Uuid
  phoneE164     String?   @unique @map("phone_e164")
  email         String?   @unique @db.Citext
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz()
  passwordHash  String?   @map("password_hash")
  googleId      String?   @unique @map("google_id")
  authProvider  String    @map("auth_provider") // 'otp' | 'google' | 'email'
  primaryRole   String    @default("user") @map("primary_role") // 'user' | 'organiser' | 'vendor'
  isVerified    Boolean   @default(false) @map("is_verified")
  // Step 8: orthogonal to primaryRole — a user can be {user, organiser} AND admin.
  // Set by direct DB access or by an existing SuperAdmin. Never elevated via API.
  isAdmin       Boolean   @default(false) @map("is_admin")
  displayName   String?   @map("display_name")
  avatarUrl     String?   @map("avatar_url")
  city          String?
  // Set the first time a user picks a role on /onboarding/role.
  // Null means they haven't onboarded yet and the app routes them to that page.
  onboardedAt   DateTime? @map("onboarded_at") @db.Timestamptz()
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz()

  businessProfiles  BusinessProfile[]
  sessions          UserSession[]
  bookings          Booking[]
  reviews           Review[]
  following         Follower[]
  adminActions      AdminAuditLog[]   @relation("AuditActor")
  notifications     Notification[]
  kycRequests       VerificationRequest[]
  subscriptions     Subscription[]
  societyPosts      SocietyPost[]
  postReplies       PostReply[]
  applications      EventApplication[] @relation("ApplicationApplicant")
  productEnquiries  ProductEnquiry[]   @relation("EnquiryFrom")

  @@index([phoneE164])
  @@index([email])
  @@index([googleId])
  @@index([isAdmin])
  @@map("users")
}

// =================================================================
// USER_SESSIONS  —  one row per active refresh-token (Step 3)
// We hash the refresh token; the plaintext only lives on the client.
// Rotation: each refresh issues a new token + a new row; the old row is revoked.
// =================================================================
model UserSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash")
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz()
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  lastUsedAt       DateTime  @default(now()) @map("last_used_at") @db.Timestamptz()
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz()
  // Forensics (lightweight at MVP; expand in Step 5)
  ip               String?
  userAgent        String?   @map("user_agent")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([refreshTokenHash])
  @@map("user_sessions")
}

// =================================================================
// BUSINESS_PROFILES  —  the public face of an organiser or vendor
// =================================================================
model BusinessProfile {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  username       String   @unique
  displayName    String   @map("display_name")
  type           String // 'organiser' | 'vendor'
  bio            String?  @db.Text
  // Facebook-style profile assets — public-readable URLs (R2/S3 or seed default).
  avatarUrl      String?  @map("avatar_url")
  coverUrl       String?  @map("cover_url")
  // Optional human-friendly location line, e.g. "Noida, Uttar Pradesh".
  location       String?
  // Social + web presence — six absolute URLs the owner curates from their
  // own accounts. All optional, rendered as a row of brand icons.
  websiteUrl     String?  @map("website_url")
  instagramUrl   String?  @map("instagram_url")
  facebookUrl    String?  @map("facebook_url")
  twitterUrl     String?  @map("twitter_url")
  linkedinUrl    String?  @map("linkedin_url")
  youtubeUrl     String?  @map("youtube_url")
  verified       Boolean  @default(false)
  followersCount Int      @default(0) @map("followers_count")
  postsCount     Int      @default(0) @map("posts_count")
  avgRating      Decimal  @default(0) @map("avg_rating") @db.Decimal(3, 2)
  kycStatus      String   @default("pending") @map("kyc_status")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user         User               @relation(fields: [userId], references: [id])
  events       Event[]
  followers    Follower[]
  posts        Post[]
  applications EventApplication[]
  products     Product[]
  enquiries    ProductEnquiry[]

  @@index([userId])
  @@index([type, verified])
  @@map("business_profiles")
}

// =================================================================
// POSTS — Facebook-style content from a business profile.
// Followers see these on their feed; anyone can view on /org/[username].
// =================================================================
model Post {
  id          String   @id @default(uuid()) @db.Uuid
  profileId   String   @map("profile_id") @db.Uuid
  // 'text' (plain announcement) | 'event' (auto-post when an event launches) | 'image'
  kind        String   @default("text")
  content     String   @db.Text
  // Up to 4 image URLs. Stored as JSON for flexibility.
  mediaUrls   Json?    @map("media_urls")
  // If this post is linked to an event launch.
  eventId     String?  @map("event_id") @db.Uuid
  // Denormalised counters bumped by triggers (PostLike / PostComment writes).
  likesCount    Int    @default(0) @map("likes_count")
  commentsCount Int    @default(0) @map("comments_count")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz()

  profile  BusinessProfile @relation(fields: [profileId], references: [id])
  likes    PostLike[]
  comments PostComment[]

  @@index([profileId, createdAt])
  @@index([createdAt])
  @@map("posts")
}

// One row per (post, user) — toggling re-likes uses upsert + delete.
model PostLike {
  postId    String   @map("post_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([userId])
  @@map("post_likes")
}

model PostComment {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz()

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([userId])
  @@map("post_comments")
}

// =================================================================
// PRODUCTS  —  vendor-only catalogue items shown on /org/<username>.
// Stall owners list their products (handmade goods, food items, etc.).
// Public users browse and tap "Enquire Now" which creates a
// ProductEnquiry row that lands in the owner's enquiries inbox.
// =================================================================
model Product {
  id             String   @id @default(uuid()) @db.Uuid
  profileId      String   @map("profile_id") @db.Uuid  // stall-owner BusinessProfile
  name           String
  description    String?  @db.Text
  category       String?
  priceFromPaise Int      @map("price_from_paise")
  imageUrls      String[] @map("image_urls")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  profile        BusinessProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  enquiries      ProductEnquiry[]

  @@index([profileId, isActive])
  @@map("products")
}

// =================================================================
// PRODUCT_ENQUIRIES  —  buyer-to-stall-owner messages.
// =================================================================
model ProductEnquiry {
  id           String    @id @default(uuid()) @db.Uuid
  productId    String    @map("product_id") @db.Uuid
  fromUserId   String    @map("from_user_id") @db.Uuid
  toProfileId  String    @map("to_profile_id") @db.Uuid
  message      String    @db.Text
  buyerName    String?   @map("buyer_name")
  buyerPhone   String?   @map("buyer_phone")
  buyerEmail   String?   @map("buyer_email")
  status       String    @default("new") // 'new' | 'read' | 'replied' | 'closed'
  ownerReply   String?   @map("owner_reply") @db.Text
  repliedAt    DateTime? @map("replied_at") @db.Timestamptz()
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  fromUser  User            @relation("EnquiryFrom", fields: [fromUserId], references: [id])
  toProfile BusinessProfile @relation(fields: [toProfileId], references: [id])

  @@index([toProfileId, status, createdAt])
  @@index([fromUserId, createdAt])
  @@map("product_enquiries")
}

// =================================================================
// SOCIETIES
// =================================================================
model Society {
  id              String   @id @default(uuid()) @db.Uuid
  slug            String   @unique
  name            String
  city            String
  type            String
  centroidLat     Decimal  @map("centroid_lat") @db.Decimal(10, 8)
  centroidLng     Decimal  @map("centroid_lng") @db.Decimal(11, 8)
  reputationScore Decimal  @default(0) @map("reputation_score") @db.Decimal(5, 2)
  eventsCount     Int      @default(0) @map("events_count")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  events Event[]
  posts  SocietyPost[]

  @@index([city])
  @@map("societies")
}

// =================================================================
// VERIFICATION_REQUESTS  —  KYC case file for a business profile.
// Multiple documents linked via KycDocument.
// =================================================================
model VerificationRequest {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  businessProfileId String    @map("business_profile_id") @db.Uuid
  status            String    @default("submitted") // 'submitted' | 'in_review' | 'approved' | 'rejected'
  companyName       String?   @map("company_name")
  registrationType  String?   @map("registration_type") // 'proprietorship' | 'llp' | 'rwa' | 'society' | 'company'
  registrationNo    String?   @map("registration_no")
  panNumber         String?   @map("pan_number")
  aadhaarLast4      String?   @map("aadhaar_last4")
  gstin             String?
  rwaPermissionNote String?   @map("rwa_permission_note")
  reviewerNote      String?   @map("reviewer_note")
  decidedAt         DateTime? @map("decided_at") @db.Timestamptz()
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user      User           @relation(fields: [userId], references: [id])
  documents KycDocument[]

  @@index([businessProfileId])
  @@index([status])
  @@map("verification_requests")
}

model KycDocument {
  id          String   @id @default(uuid()) @db.Uuid
  requestId   String   @map("request_id") @db.Uuid
  kind        String // 'pan' | 'aadhaar' | 'gst' | 'rwa_permission' | 'org_proof' | 'other'
  filename    String
  contentType String   @map("content_type")
  sizeBytes   Int      @map("size_bytes")
  storageKey  String   @map("storage_key") // local path in dev, R2 key in prod
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  request VerificationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@map("kyc_documents")
}

// =================================================================
// SUBSCRIPTIONS  —  Society Plus / Vendor Plus / Organiser Pro.
// Monthly debit from the user's wallet via a Bull repeatable job.
// =================================================================
model SubscriptionPlan {
  id              String   @id @default(uuid()) @db.Uuid
  code            String   @unique // 'society_plus' | 'vendor_plus' | 'organiser_pro'
  name            String
  pricePaise      Int      @map("price_paise")
  billingCycle    String   @default("monthly") @map("billing_cycle")
  benefits        Json     @default("[]")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  subscriptions   Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  planId        String    @map("plan_id") @db.Uuid
  status        String    @default("active") // 'active' | 'cancelled' | 'past_due'
  startedAt     DateTime  @default(now()) @map("started_at") @db.Timestamptz()
  nextBillingAt DateTime  @map("next_billing_at") @db.Timestamptz()
  cancelledAt   DateTime? @map("cancelled_at") @db.Timestamptz()
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user User             @relation(fields: [userId], references: [id])
  plan SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([userId, status])
  @@index([nextBillingAt, status])
  @@map("subscriptions")
}

// =================================================================
// SOCIETY_POSTS  —  community notice board on the society page.
// Authored by any signed-in user who follows the society / is a resident
// (resident-flag deferred; for MVP any authed user can post).
// =================================================================
model SocietyPost {
  id          String   @id @default(uuid()) @db.Uuid
  societyId   String   @map("society_id") @db.Uuid
  authorId    String   @map("author_id") @db.Uuid
  title       String
  body        String   @db.Text
  moderation  String   @default("approved") // 'approved' | 'flagged' | 'hidden'
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  pinnedAt    DateTime? @map("pinned_at") @db.Timestamptz()

  society Society     @relation(fields: [societyId], references: [id])
  author  User        @relation(fields: [authorId], references: [id])
  replies PostReply[]

  @@index([societyId, createdAt(sort: Desc)])
  @@map("society_posts")
}

model PostReply {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  authorId  String   @map("author_id") @db.Uuid
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  post   SocietyPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User        @relation(fields: [authorId], references: [id])

  @@index([postId, createdAt])
  @@map("post_replies")
}

// =================================================================
// EVENTS
// =================================================================
model Event {
  id          String   @id @default(uuid()) @db.Uuid
  organiserId String   @map("organiser_id") @db.Uuid
  societyId   String?  @map("society_id") @db.Uuid
  slug        String   @unique
  title       String
  description String   @db.Text
  coverImages String[] @map("cover_images")
  startsAt    DateTime @map("starts_at") @db.Timestamptz()
  endsAt      DateTime @map("ends_at") @db.Timestamptz()
  latitude    Decimal  @db.Decimal(10, 8)
  longitude   Decimal  @db.Decimal(11, 8)
  addressText String   @map("address_text")
  capacity    Int?
  status      String   @default("draft")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  organiser    BusinessProfile    @relation(fields: [organiserId], references: [id])
  society      Society?           @relation(fields: [societyId], references: [id])
  stalls       Stall[]
  reviews      Review[]
  applications EventApplication[]

  @@index([status, startsAt])
  @@index([societyId])
  @@index([organiserId])
  @@map("events")
}

// =================================================================
// EVENT_APPLICATIONS — vendor applies to book a stall at an event.
// Statuses follow the master spec's progression: submitted → under_review
// → approved → payment_pending → booked, with rejected as a terminal state.
// =================================================================
model EventApplication {
  id              String   @id @default(uuid()) @db.Uuid
  eventId         String   @map("event_id") @db.Uuid
  applicantUserId String   @map("applicant_user_id") @db.Uuid
  // The vendor's BusinessProfile if they have one. Optional — solo vendors
  // can apply with just a business name.
  profileId       String?  @map("profile_id") @db.Uuid
  // Snapshot fields the vendor enters at apply time.
  businessName    String   @map("business_name")
  category        String
  productType     String?  @map("product_type")
  message         String?  @db.Text
  // Workflow state machine.
  status          String   @default("submitted")
  // Set when the organiser decides (approve / reject).
  decisionAt      DateTime? @map("decision_at") @db.Timestamptz()
  decisionBy      String?  @map("decision_by") @db.Uuid // organiser user id
  rejectionReason String?  @map("rejection_reason") @db.Text
  // After approval → payment → booking. Optional FK to the resulting booking row.
  bookingId       String?  @map("booking_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  event     Event            @relation(fields: [eventId], references: [id])
  applicant User             @relation("ApplicationApplicant", fields: [applicantUserId], references: [id])
  profile   BusinessProfile? @relation(fields: [profileId], references: [id])

  // One vendor can only have ONE active application per event. Soft-rejection
  // means we re-allow via separate workflow — at MVP, enforce uniqueness.
  @@unique([eventId, applicantUserId])
  @@index([eventId, status])
  @@index([applicantUserId, status])
  @@index([profileId])
  @@map("event_applications")
}

// =================================================================
// STALLS
// =================================================================
model Stall {
  id         String   @id @default(uuid()) @db.Uuid
  eventId    String   @map("event_id") @db.Uuid
  category   String
  pricePaise Int      @map("price_paise")
  available  Int      @default(1)
  booked     Int      @default(0)
  facilities Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  event    Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([eventId, category])
  @@map("stalls")
}

// =================================================================
// NOTIFICATIONS  —  one row per delivery. We poll unread count from the
// frontend; SSE/web-push wraps the same table in Step 7d.2.
// =================================================================
model Notification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  type      String // 'booking_received' | 'review_received' | 'new_follower' | 'kyc_approved' | 'kyc_rejected' | ...
  title     String
  body      String?   @db.Text
  link      String? // e.g. '/events/sector-76-diwali-mela'
  meta      Json      @default("{}")
  readAt    DateTime? @map("read_at") @db.Timestamptz()
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, readAt])
  @@map("notifications")
}

// =================================================================
// ADMIN_AUDIT_LOGS  —  immutable record of every admin action.
// Inserted by AdminService inside the same transaction as the mutation.
// Never updated or deleted from application code; we'll add a Postgres
// row-level rule that rejects UPDATE/DELETE in Step 8c.
// =================================================================
model AdminAuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorId     String   @map("actor_id") @db.Uuid
  action      String // e.g. 'approve_kyc' | 'reject_kyc' | 'take_down_event'
  targetTable String   @map("target_table")
  targetId    String   @map("target_id") @db.Uuid
  diff        Json     @default("{}")
  note        String?  @db.Text
  ip          String?
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  actor User @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([targetTable, targetId])
  @@index([createdAt(sort: Desc)])
  @@map("admin_audit_logs")
}

// =================================================================
// FOLLOWERS  —  many-to-many junction. A user follows a business_profile.
// followersCount on BusinessProfile is denormalized; kept in sync inside
// followers.service.ts via a Prisma transaction.
// =================================================================
model Follower {
  id                String   @id @default(uuid()) @db.Uuid
  followerUserId    String   @map("follower_user_id") @db.Uuid
  businessProfileId String   @map("business_profile_id") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()

  follower User            @relation(fields: [followerUserId], references: [id])
  profile  BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@unique([followerUserId, businessProfileId])
  @@index([businessProfileId])
  @@map("followers")
}

// =================================================================
// REVIEWS  —  star ratings (1-5) + optional text body, tied to an event.
// Organiser-level avg_rating on BusinessProfile is recomputed after every
// review using Bayesian shrinkage — see reviews.service.ts.
// One review per (authorId, eventId) enforced by @@unique.
// =================================================================
model Review {
  id               String   @id @default(uuid()) @db.Uuid
  authorId         String   @map("author_id") @db.Uuid
  eventId          String   @map("event_id") @db.Uuid
  stars            Int      @db.SmallInt
  body             String?  @db.Text
  moderationStatus String   @default("approved") @map("moderation_status") // 'approved' | 'flagged' | 'hidden'
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz()

  author User  @relation(fields: [authorId], references: [id])
  event  Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([authorId, eventId])
  @@index([eventId])
  @@index([authorId])
  @@map("reviews")
}

// =================================================================
// BOOKINGS  —  vendor reserves a stall slot.
// On insert: stall.available -= 1, stall.booked += 1, plus a 3-leg
// wallet transfer (see bookings.service.ts).
// Money split is captured here for trivial reconciliation:
//   amountPaise = platformFeePaise + escrowHeldPaise
// =================================================================
model Booking {
  id               String    @id @default(uuid()) @db.Uuid
  stallId          String    @map("stall_id") @db.Uuid
  userId           String    @map("user_id") @db.Uuid // who booked (vendor)
  amountPaise      Int       @map("amount_paise") // total price paid
  platformFeePaise Int       @map("platform_fee_paise") // our 10% take
  escrowHeldPaise  Int       @map("escrow_held_paise") // 90% held for organiser until event ends
  status           String    @default("confirmed") // 'confirmed' | 'cancelled' | 'released'
  bookingTxnId     String    @map("booking_txn_id") @db.Uuid // links to wallet_entries.txn_id
  refundTxnId      String?   @map("refund_txn_id") @db.Uuid // set when cancelled with refund
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  cancelledAt      DateTime? @map("cancelled_at") @db.Timestamptz()
  releasedAt       DateTime? @map("released_at") @db.Timestamptz()

  stall Stall @relation(fields: [stallId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([stallId, status])
  @@map("bookings")
}

// =================================================================
// WALLETS  —  one row per owner (user, business, or platform-house)
// `balancePaise` is a materialised view of sum(credits) - sum(debits)
// for the 'available' bucket. `pendingPaise` mirrors the 'pending'
// (escrow) bucket. Both kept in sync inside the WalletService
// transaction — see wallet.service.ts.
// =================================================================
model Wallet {
  id           String   @id @default(uuid()) @db.Uuid
  ownerType    String   @map("owner_type") // 'user' | 'business' | 'platform'
  ownerId      String?  @map("owner_id") @db.Uuid // null for the platform-house wallet
  currency     String   @default("INR")
  balancePaise Int      @default(0) @map("balance_paise") // available
  pendingPaise Int      @default(0) @map("pending_paise") // held in escrow
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  entries WalletEntry[]

  @@unique([ownerType, ownerId])
  @@map("wallets")
}

// =================================================================
// WALLET_ENTRIES  —  append-only double-entry ledger.
// Every transaction produces ≥2 entries sharing a txnId.
// The invariant sum(D) == sum(C) must hold across the table at rest.
// =================================================================
model WalletEntry {
  id          String   @id @default(uuid()) @db.Uuid
  walletId    String   @map("wallet_id") @db.Uuid
  txnId       String   @map("txn_id") @db.Uuid
  direction   String // 'D' (debit) or 'C' (credit)
  amountPaise Int      @map("amount_paise")
  reason      String // 'topup' | 'stall_booking' | 'commission' | 'refund' | 'withdrawal' | 'manual_adjustment'
  bucket      String   @default("available") // 'available' | 'pending' (escrow)
  meta        Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId, createdAt(sort: Desc)])
  @@index([txnId])
  @@map("wallet_entries")
}

// =================================================================
// WITHDRAWAL_REQUESTS  —  user/business wants money out to their bank.
// Created in 'pending' state; admin approves → released; admin rejects → returned.
// On approval, the user's wallet is debited and the platform-house credited
// (because the actual money is now in a manual settlement queue).
// =================================================================
model WithdrawalRequest {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  amountPaise    Int       @map("amount_paise")
  feePaise       Int       @default(0) @map("fee_paise") // ₹5 flat in production
  status         String    @default("pending") // 'pending' | 'approved' | 'rejected' | 'paid'
  bankAccountRef String?   @map("bank_account_ref")
  ifsc           String?
  accountHolder  String?   @map("account_holder")
  note           String?
  txnId          String?   @map("txn_id") @db.Uuid // wallet txn when approved
  decidedById    String?   @map("decided_by_id") @db.Uuid
  decidedAt      DateTime? @map("decided_at") @db.Timestamptz()
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@map("withdrawal_requests")
}

// =================================================================
// FEATURED_LISTINGS  —  paid boost. Organiser pays from their wallet,
// money goes to platform-house. While active, the event gets ranking boost
// in discovery (multiplier on the composite score).
// =================================================================
model FeaturedListing {
  id          String   @id @default(uuid()) @db.Uuid
  eventId     String   @map("event_id") @db.Uuid
  tier        String // 'boost' (₹499/3d) | 'spotlight' (₹1499/7d) | 'city' (₹2499/1d)
  pricePaise  Int      @map("price_paise")
  startsAt    DateTime @map("starts_at") @db.Timestamptz()
  endsAt      DateTime @map("ends_at") @db.Timestamptz()
  txnId       String   @map("txn_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([eventId])
  @@index([endsAt])
  @@map("featured_listings")
}

// =================================================================
// PAYMENT_EVENTS  —  idempotent log of PSP events (PayU webhook).
// `externalId` is the PSP's transaction id; UNIQUE prevents replay.
// In dev (provider='stub') the event is materialised in-process by
// PaymentsService.simulateInstantTopup().
// =================================================================
model PaymentEvent {
  id            String   @id @default(uuid()) @db.Uuid
  provider      String // 'payu' | 'stub'
  externalId    String   @unique @map("external_id")
  status        String // 'pending' | 'success' | 'failed'
  amountPaise   Int      @map("amount_paise")
  payloadRaw    Json     @map("payload_raw")
  userId        String?  @map("user_id") @db.Uuid
  walletEntryId String?  @unique @map("wallet_entry_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([userId])
  @@index([status])
  @@map("payment_events")
}
