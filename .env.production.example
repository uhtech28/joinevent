# ============================================================
# .env.production — copy to .env.production and fill in.
# Loaded by docker-compose.deploy.yml and every service via env_file.
# Never commit the real .env.production to git.
# ============================================================

# ---- The domain Caddy serves on (no scheme, no trailing slash) ----
# Example: demo.joinevents.in
DOMAIN=CHANGE_ME.example.com

# ---- Postgres ----
POSTGRES_USER=joinevents
POSTGRES_PASSWORD=CHANGE_ME_postgres_password
POSTGRES_DB=joinevents

# ---- API runtime ----
NODE_ENV=production
PORT=4000
DATABASE_URL=postgresql://joinevents:CHANGE_ME_postgres_password@postgres:5432/joinevents?schema=public
REDIS_URL=redis://redis:6379

# Front-end origin allowed by CORS. Match DOMAIN above.
CORS_ORIGINS=https://CHANGE_ME.example.com

# ---- Auth (REQUIRED in prod) ----
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_at_least_32_random_characters_long_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# ---- Storage ----
# 'local' keeps uploads in a docker volume mounted at /app/storage.
# Swap to 's3' or 'r2' once you have a bucket — see apps/api/src/storage/.
STORAGE_DRIVER=local
STORAGE_PUBLIC_URL=https://CHANGE_ME.example.com/api/v1/storage

# ---- Web (Next.js) ----
# Browser-side base URL — must point at the public API path on your domain.
NEXT_PUBLIC_API_URL=https://CHANGE_ME.example.com/api/v1

# ---- Optional integrations (leave blank to disable for client testing) ----
# Meilisearch — empty falls back to Postgres FTS (fine for first months)
MEILI_HOST=
MEILI_MASTER_KEY=

# Payments — leave blank to use the dev stub (instant credit, no real money)
PAYU_KEY=
PAYU_SALT=

# SMS OTP — leave blank to echo OTP in the API response (preview-mode only)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# Email — leave blank to skip verification emails
POSTMARK_TOKEN=
POSTMARK_FROM=

# Error monitoring — leave blank to disable Sentry
SENTRY_DSN=

# ---- Queue worker ----
QUEUE_DISABLED=false
